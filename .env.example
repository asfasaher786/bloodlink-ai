# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database (MongoDB Atlas — leave blank to use in-memory fallback) ──────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# ── AI (Google Gemini) ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── CORS / URLs ───────────────────────────────────────────────────────────────
# For split deployment (Vercel frontend + Render backend):
FRONTEND_URL=https://bloodlink-ai.vercel.app
BACKEND_URL=https://bloodlink-ai.onrender.com

# For frontend — set in Vercel dashboard or .env.local:
# VITE_API_URL=https://bloodlink-ai.onrender.com
